<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Foochow Scholar</title>
    <link rel="stylesheet" href="style.css">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body>

    <div class="app-container">
        <div class="glow"></div>

        <header class="header">
            <div class="badge">HERITAGE PROJECT</div>
        </header>

        <main class="content">
            <div class="intro">
                <h1>Foochow Scholar</h1>
                <p>A digital gateway to the Hockchiu dialect. Explore the sounds and scripts of the Min River culture.</p>
            </div>

            <div class="button-centerpiece">
                <a href="https://tinyurl.com/FoochowApp" target="_blank" class="app-trigger">
                    <div class="logo-wrapper">
                        <img src="logo-fc-app.png" alt="Foochow Scholar" class="main-logo">
                        <div class="ring-animation"></div>
                        <div class="ring-animation delay"></div>
                    </div>
                    <span class="tap-label">TAP TO LAUNCH APP</span>
                </a>
            </div>
        </main>

        <footer class="footer">
            <div class="swipe-indicator"></div>
        </footer>
    </div>

</body>
</html>
